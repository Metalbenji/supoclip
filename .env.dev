# Environment overrides for the dev instance (runs alongside your main supoclip)
# Port-shifted so nothing clashes with the original.

APP_HOST=localhost

# Shifted ports (+1 offset to avoid conflicts)
FRONTEND_HOST_PORT=3001
BACKEND_HOST_PORT=8001
POSTGRES_HOST_PORT=5434
REDIS_HOST_PORT=6380

BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
BETTER_AUTH_SECRET=supoclip_dev_secret_DIM_UNHIGHLIGHTED

# Copy your API keys from your main .env file into here:
ASSEMBLY_AI_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
ZAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

LLM=openai:gpt-5-mini
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=auto
WHISPER_CHUNKING_ENABLED=true
WHISPER_CHUNK_DURATION_SECONDS=1200
WHISPER_CHUNK_OVERLAP_SECONDS=8
TRANSCRIPTION_PROVIDER=local

YTDLP_COOKIES_FILE=/app/.secrets/youtube.cookies.txt

MEDIAPIPE_FACE_MODEL_PATH=./backend/models/blaze_face_short_range.tflite
MEDIAPIPE_FACE_MODEL_URL=https://storage.googleapis.com/mediapipe-models/face_detector/blaze_face_short_range/float16/1/blaze_face_short_range.tflite
MEDIAPIPE_FACE_MODEL_SHA256=b4578f35940bf5a1a655214a1cce5cab13eba73c1297cd78e1a04c2380b0152f
MEDIAPIPE_FACE_MODEL_AUTO_DOWNLOAD=true

WORKER_MAX_JOBS=2
WORKER_JOB_TIMEOUT_SECONDS=21600

ARQ_QUEUE_NAME_LOCAL=arq:queue:local-dev
ARQ_QUEUE_NAME_LOCAL_GPU=arq:queue:local-gpu-dev
ARQ_QUEUE_NAME_ASSEMBLY=arq:queue:assembly-dev

WORKER2_MAX_JOBS=1
WORKER2_WHISPER_DEVICE=auto
WORKER_GPU_WHISPER_DEVICE=cuda

ENABLE_MULTI_WORKER=false
ENABLE_GPU_WORKER=false
ENABLE_ASSEMBLY_WORKER=false

BETTER_AUTH_SECRET=supoclip_dev_secret_DIM_UNHIGHLIGHTED
ADMIN_API_KEY=

POSTGRES_DB=supoclip
POSTGRES_USER=supoclip
POSTGRES_PASSWORD=supoclip_password

COMPOSE_DOCKER_CLI_BUILD=1
DOCKER_BUILDKIT=1
DOCKER_GPU_REQUEST=all
DOCKER_GPU_REQUEST_WORKER2=all
DOCKER_GPU_REQUEST_WORKER_GPU=all
DOCKER_GPU_REQUEST_WORKER_ASSEMBLY=all

SECRET_ENCRYPTION_KEY=
WHISPER_CACHE_HOST_DIR=./backend/.cache/whisper-dev
